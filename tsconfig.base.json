{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@mrshamshiri/cost-core": ["packages/cost-core/src/index.ts"],
      "@mrshamshiri/agent-core": ["packages/agent-core/src/index.ts"],
      "@mrshamshiri/provider-openai-compatible": ["packages/provider-openai-compatible/src/index.ts"],
      "@mrshamshiri/provider-anthropic-like": ["packages/provider-anthropic-like/src/index.ts"]
    }
  }
}

